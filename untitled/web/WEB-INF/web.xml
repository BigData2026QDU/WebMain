<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- JSON测试Servlet -->
    <servlet>
        <servlet-name>TestServlet</servlet-name>
        <servlet-class>org.example.Servlet.TestServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TestServlet</servlet-name>
        <url-pattern>/api/test</url-pattern>
    </servlet-mapping>

    <!-- 数据库测试Servlet -->
    <servlet>
        <servlet-name>DatabaseTestServlet</servlet-name>
        <servlet-class>org.example.Servlet.DatabaseTestServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DatabaseTestServlet</servlet-name>
        <url-pattern>/api/db</url-pattern>
    </servlet-mapping>

    <!-- Hibernate测试Servlet -->
    <servlet>
        <servlet-name>HibernateTestServlet</servlet-name>
        <servlet-class>org.example.Servlet.HibernateTestServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HibernateTestServlet</servlet-name>
        <url-pattern>/api/hibernate</url-pattern>
    </servlet-mapping>

    <!-- 图表数据Servlet -->
    <servlet>
        <servlet-name>ChartDataServlet</servlet-name>
        <servlet-class>org.example.Servlet.ChartDataServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ChartDataServlet</servlet-name>
        <url-pattern>/api/chart/family-impact</url-pattern>
    </servlet-mapping>

</web-app>